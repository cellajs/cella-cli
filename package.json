{
  "name": "@cellajs/cli",
  "version": "0.0.2",
  "private": false,
  "license": "MIT",
  "description": "CLI for syncing and managing apps with upstream Cella.",
  "repository": {
    "type": "git",
    "url": "https://github.com/cellajs/cella-cli"
  },
  "homepage": "https://cellajs.com",
  "author": "CellaJS <info@cellajs.com>",
  "engines": {
    "node": "24.x"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "index.js",
    "README.md"
  ],
  "bin": {
    "cella": "index.js"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "start": "tsx index.ts",
    "clean": "rimraf ./dist",
    "build": "tsup",
    "test-build": "pnpm run build && node index.js --help",
    "prepublishOnly": "pnpm run test:release",
    "check": "pnpm ts && pnpm biome check --write .",
    "ts": "tsgo --pretty",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:release": "pnpm run build && vitest run --config vitest.release.config.ts",
    "test:watch": "vitest",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@inquirer/core": "^11.2.1",
    "@inquirer/prompts": "^8.5.2",
    "commander": "^15.0.0",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@evilmartians/lefthook": "^2.1.9",
    "@types/node": "24.10.13",
    "@typescript/native-preview": "7.0.0-dev.20260702.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cella",
    "cellajs",
    "cli",
    "sync",
    "template"
  ],
  "packageManager": "pnpm@11.8.0",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "feat",
          "fix",
          "perf",
          "refactor",
          "revert",
          "docs",
          "chore",
          "build",
          "ci",
          "style",
          "test"
        ]
      ],
      "header-max-length": [
        2,
        "always",
        120
      ],
      "body-max-line-length": [
        0,
        "always",
        200
      ],
      "footer-max-line-length": [
        0,
        "always",
        200
      ]
    }
  }
}
